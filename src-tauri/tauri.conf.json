{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Knock",
  "version": "0.4.4",
  "identifier": "io.github.hihenen.knock",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Knock",
        "width": 1120,
        "height": 980,
        "minWidth": 640,
        "minHeight": 540,
        "center": true,
        "focus": true,
        "alwaysOnTop": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
